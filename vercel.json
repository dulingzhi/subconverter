{
  "version": 2,
  "builds": [
    {
      "src": "src/vercel.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/vercel.ts"
    }
  ],
  "functions": {
    "src/vercel.ts": {
      "maxDuration": 10
    }
  },
  "env": {
    "PORT": "8080"
  }
}
